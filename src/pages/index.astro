---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Luca Lazarte — Frontend Developer"
  description="Portfolio de Luca Lazarte, desarrollador frontend."
  variant="home"
>
  <!--
    SCROLL NORMAL: cada sección ocupa h-screen, se apilan y el usuario
    hace scroll para recorrerlas. Sin sticky = sin stacking.

    Para reactivar el efecto stacking, agregar a cada section:
    "sticky top-0"  y  z-[10 / 20 / 30 / 40 / 50]
  -->
  <div>

    <section class="h-screen w-full overflow-hidden" aria-label="Presentación">
      <Hero />
    </section>

    <section class="h-screen w-full overflow-hidden" aria-label="Sobre mí">
      <About />
    </section>

    <section class="h-screen w-full overflow-hidden" aria-label="Proyectos">
      <Projects />
    </section>

    <section class="h-screen w-full overflow-hidden" aria-label="Experiencia">
      <Experience />
    </section>

    <section class="h-screen w-full overflow-hidden" aria-label="Contacto">
      <Contact />
    </section>

  </div>
</Layout>