---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Luca Lazarte — Frontend Developer"
  description="Portfolio de Luca Lazarte, desarrollador frontend."
  variant="home"
>
  <div class="relative">

    <!-- z-10: base, primera capa visible -->
    <section class="sticky top-0 h-screen w-full overflow-hidden z-10" aria-label="Presentación">
      <Hero />
    </section>

    <!-- z-20: se desliza encima del Hero -->
    <section class="sticky top-0 h-screen w-full overflow-hidden z-20" aria-label="Sobre mí">
      <About />
    </section>

    <!-- z-30: se desliza encima de About -->
    <section class="sticky top-0 h-screen w-full overflow-hidden z-30" aria-label="Proyectos">
      <Projects />
    </section>

    <!-- z-40: se desliza encima de Projects -->
    <section class="sticky top-0 h-screen w-full overflow-hidden z-40" aria-label="Experiencia">
      <Experience />
    </section>
    
    <section class="sticky top-0 h-screen w-full overflow-hidden z-50" aria-label="Contacto">
      <Contact />
    </section>
  </div>
</Layout>