---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
---

<Layout
  title="Luca Lazarte — Frontend Developer"
  description="Portfolio de Luca Lazarte"
  variant="home"
>
  <div class="relative">

    <section
      class="sticky top-0 h-screen w-full overflow-hidden z-10"
      aria-label="Presentación"
    >
      <Hero />
    </section>

    <section
      class="sticky top-0 h-screen w-full overflow-hidden z-20"
      aria-label="Sobre mí"
    >
      <About />
    </section>

  </div>
</Layout>