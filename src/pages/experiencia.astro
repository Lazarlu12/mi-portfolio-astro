---
import Layout from '../layouts/Layout.astro';
import Experience from '../components/Experience.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Experiencia — Luca Lazarte"
  description="Experiencia y trayectoria de Luca Lazarte como desarrollador frontend."
  variant="page"
>
  <main class="min-h-screen flex flex-col">
    <section class="flex-1" aria-label="Experiencia">
      <Experience mode="page" />
    </section>
    <Footer />
  </main>
</Layout>