---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Sobre mí — Luca Lazarte"
  description="Conocé más sobre Luca Lazarte, desarrollador frontend estudiante de UTN Tucumán."
  variant="page"
>
  <main class="min-h-screen flex flex-col">
    <section class="flex-1" aria-label="Sobre mí">
      <About mode="page" />
    </section>
    <Footer />
  </main>
</Layout>