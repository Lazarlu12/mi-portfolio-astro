---
import { data } from '../data/portfolioData';
---

<!--
  h-full + flex para ocupar todo el contenedor sticky del stacking
  El fondo tiene un tono muy ligeramente diferente al Hero para
  que se note la separación visual cuando una sección tapa a la otra
-->
<div class="h-full flex flex-col items-center justify-center px-8 md:px-16 bg-[#212121]">

  <div class="max-w-3xl w-full text-center">

    <h2 class="font-display font-semibold tracking-tight text-high">
      Sobre mí
    </h2>

    <p class="text-mid text-lg md:text-xl leading-relaxed">
      {data.personalInfo.about}
    </p>

    <!-- Skills como pills debajo del texto -->
    <div class="flex flex-wrap gap-2 justify-center mt-10">
      {data.skills.map((skill) => (
        <span class="px-3 py-1 text-xs border border-white/10 text-low rounded-full hover:border-accent hover:text-accent transition-all duration-200">
          {skill}
        </span>
      ))}
    </div>

  </div>

</div>