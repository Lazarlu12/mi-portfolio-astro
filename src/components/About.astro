---
// src/components/About.astro
import { data } from '../data/portfolioData';
import SkillsCarousel from './SkillsCarousel.astro';

interface Props {
  // 'home'  → h-full + justify-center, para el contenedor sticky h-screen del stacking
  // 'page'  → min-h-full + py-20, flujo natural para la página /sobre-mi
  mode?: 'home' | 'page';
}

const { mode = 'home' } = Astro.props;
---

<!--
  Las clases del contenedor cambian según el contexto:

  home: h-full llena el sticky container de h-screen. justify-center
        centra el contenido verticalmente (el espacio arriba/abajo lo
        maneja el propio contenedor sticky).

  page: min-h-full permite crecer si el contenido es más alto que el
        espacio disponible. py-20 da respiro vertical natural. Sin
        justify-center para que el contenido fluya desde arriba.
-->
<div
  class:list={[
    'flex flex-col items-center px-8 md:px-16 bg-[#212121]',
    mode === 'home'
      ? 'h-full justify-center'
      : 'min-h-full justify-center py-20 md:py-24',
  ]}
>
  <div class="max-w-3xl w-full text-center">

    <span class="text-accent text-xs uppercase tracking-[0.3em] mb-4 block">
      Quién soy
    </span>

    <h2 class="text-3xl md:text-4xl font-bold text-high mb-8 leading-tight">
      Sobre mí
    </h2>

    <p class="text-mid text-lg md:text-xl leading-relaxed">
      {data.personalInfo.about}
    </p>

    <!-- ✅ Carrusel infinito reemplaza las pills estáticas -->
    <SkillsCarousel skills={data.skills} />

  </div>
</div>