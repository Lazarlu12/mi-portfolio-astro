---
// src/components/About.astro
import { data } from '../data/portfolioData';
import SkillsCarousel from './SkillsCarousel.astro';

interface Props {
  mode?: 'home' | 'page';
}
const { mode = 'home' } = Astro.props;
---

<!--
  Sin padding lateral en el contenedor externo → el carrusel puede ir a full-width.
  El texto sí tiene su propio padding mediante el div max-w-3xl interno.
-->
<div
  class:list={[
    'flex flex-col items-center bg-[#212121]',
    mode === 'home'
      ? 'h-full justify-center'
      : 'min-h-full justify-center py-20 md:py-24',
  ]}
>
  <!-- Texto centrado y contenido dentro de max-w-3xl con padding lateral -->
  <div class="max-w-3xl w-full text-center px-8 md:px-16">
    <span class="text-accent text-xs uppercase tracking-[0.3em] mb-4 block">
      Quién soy
    </span>

    <h2 class="text-3xl md:text-4xl font-bold text-high mb-8 leading-tight">
      Sobre mí
    </h2>

    <p class="text-mid text-lg md:text-xl leading-relaxed">
      {data.personalInfo.about}
    </p>
  </div>

  <!--
    El carrusel vive FUERA del max-w-3xl → corre de borde a borde de la sección.
    El mt-10 ya está dentro de SkillsCarousel.
  -->
  <div class="w-full">
    <SkillsCarousel skills={data.skills} />
  </div>
</div>