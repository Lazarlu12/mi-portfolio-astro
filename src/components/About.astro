---
// src/components/About.astro
import { data } from '../data/portfolioData';
import SkillsCarousel from './SkillsCarousel.astro';

interface Props {
  mode?: 'home' | 'page';
}
const { mode = 'home' } = Astro.props;

const languages = data.skills.filter(s => s.category === 'language');
const tools     = data.skills.filter(s => s.category === 'tool');
---

<div
  class:list={[
    'flex flex-col items-center bg-[#212121]',
    mode === 'home'
      ? 'h-full justify-center py-6' 
      : 'min-h-full justify-center py-12 md:py-16',
  ]}
>
  <!-- Texto: Ancho máximo reducido a 2xl y tipografía más pequeña -->
  <div class="max-w-2xl w-full text-center px-6 md:px-12">
    <h2 class="text-2xl md:text-3xl font-bold text-high mb-3 leading-tight">
      Sobre mí
    </h2>
    <p class="text-mid text-sm md:text-base leading-relaxed">
      {data.personalInfo.about}
    </p>
  </div>

  <!-- Contenedor de carruseles: Menor margen superior y menor separación interna -->
  <div class="w-full mt-6 flex flex-col gap-4">

    <!-- Carrusel 1: Lenguajes & Frameworks -->
    <div>
      <p class="text-center text-[10px] text-low uppercase tracking-[0.2em] mb-2 px-4">
        Lenguajes &amp; Frameworks
      </p>
      <SkillsCarousel skills={languages} speed={35} direction="left" />
    </div>

    <!-- Carrusel 2: Herramientas & Plataformas -->
    <div>
      <p class="text-center text-[10px] text-low uppercase tracking-[0.2em] mb-2 px-4">
        Herramientas &amp; Plataformas
      </p>
      <SkillsCarousel skills={tools} speed={28} direction="right" />
    </div>

  </div>
</div>
