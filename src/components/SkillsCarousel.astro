---
// src/components/SkillsCarousel.astro
import type { Skill } from '../types/index';

interface Props {
  skills: Skill[];
  speed?: number;
  direction?: 'left' | 'right';
}

const { skills, speed = 35, direction = 'left' } = Astro.props;

