---
// src/components/SkillsCarousel.astro
// Carrusel infinito con cards estilo tech-dark. CSS puro, sin JS.
import type { Skill } from '../types/index';

interface Props {
  skills: Skill[];
  speed?: number; // segundos por vuelta completa
}

const { skills, speed = 35 } = Astro.props;

// ─── ICON MAP ────────────────────────────────────────────────────────
// SVGs inline: zero requests externos, carga instantánea, Lighthouse happy.
// Los iconos son assets visuales → viven en el componente, no en portfolioData.
const iconMap: Record<string, string> = {

  'HTML': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#E34F26"/>
    <text x="20" y="10" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" font-weight="700" fill="rgba(255,255,255,0.65)" letter-spacing="1">HTML</text>
    <text x="20" y="33" text-anchor="middle" font-family="system-ui,sans-serif" font-size="24" font-weight="900" fill="white">5</text>
  </svg>`,

  'CSS': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#1572B6"/>
    <text x="20" y="10" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" font-weight="700" fill="rgba(255,255,255,0.65)" letter-spacing="1.5">CSS</text>
    <text x="20" y="33" text-anchor="middle" font-family="system-ui,sans-serif" font-size="24" font-weight="900" fill="white">3</text>
  </svg>`,

  'JavaScript': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#F7DF1E"/>
    <text x="26" y="33" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="900" fill="#323330">JS</text>
  </svg>`,

  'TypeScript': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#3178C6"/>
    <text x="26" y="33" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="900" fill="white">TS</text>
  </svg>`,

  'React.js': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#20232A"/>
    <ellipse cx="20" cy="20" rx="13" ry="5" stroke="#61DAFB" stroke-width="1.5"/>
    <ellipse cx="20" cy="20" rx="13" ry="5" stroke="#61DAFB" stroke-width="1.5" transform="rotate(60 20 20)"/>
    <ellipse cx="20" cy="20" rx="13" ry="5" stroke="#61DAFB" stroke-width="1.5" transform="rotate(120 20 20)"/>
    <circle cx="20" cy="20" r="2.5" fill="#61DAFB"/>
  </svg>`,

  'Tailwind CSS': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#0F172A"/>
    <text x="20" y="11" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" font-weight="600" fill="rgba(56,189,248,0.6)" letter-spacing="0.5">TAILWIND</text>
    <text x="20" y="33" text-anchor="middle" font-family="system-ui,sans-serif" font-size="20" font-weight="900" fill="#38BDF8">CSS</text>
  </svg>`,

  'Git': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#F05032"/>
    <circle cx="13" cy="28" r="3.5" fill="white"/>
    <circle cx="13" cy="12" r="3.5" fill="white"/>
    <circle cx="28" cy="18" r="3.5" fill="white"/>
    <line x1="13" y1="15.5" x2="13" y2="24.5" stroke="white" stroke-width="2"/>
    <path d="M13 12 Q20 12 28 18" stroke="white" stroke-width="2" fill="none"/>
  </svg>`,

  'Responsive Design': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#374151"/>
    <rect x="6" y="11" width="19" height="13" rx="2" stroke="white" stroke-width="1.5"/>
    <line x1="15.5" y1="24" x2="15.5" y2="28" stroke="white" stroke-width="1.5"/>
    <line x1="11" y1="28" x2="20" y2="28" stroke="white" stroke-width="1.5"/>
    <rect x="26" y="16" width="9" height="13" rx="2" stroke="white" stroke-width="1.5"/>
    <circle cx="30.5" cy="27.5" r="1" fill="white" opacity="0.6"/>
  </svg>`,

  'C#': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#6A1577"/>
    <text x="20" y="25" text-anchor="middle" font-family="system-ui,sans-serif" font-size="17" font-weight="900" fill="white">C#</text>
  </svg>`,

  'PWA': `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="8" fill="#5A0FC8"/>
    <path d="M22 4 L13 22 H20 L17 36 L28 18 H21 Z" fill="white" opacity="0.9"/>
  </svg>`,
};

const fallbackIcon = `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="40" height="40" rx="8" fill="#374151"/>
  <text x="20" y="25" text-anchor="middle" font-family="system-ui,sans-serif" font-size="14" font-weight="700" fill="rgba(255,255,255,0.4)">?</text>
</svg>`;

// Duplicamos el array para el seamless loop
const doubled = [...skills, ...skills];
---

<!--
  overflow-hidden → recorta el carrusel
  mask-image → fade en los bordes: look más premium, el carrusel "aparece" del aire
-->
<div
  class="overflow-hidden w-full mt-10"
  style="
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  "
  aria-hidden="true"
>
  <!--
    carousel-track: definido en global.css (animation-name, timing, iteration).
    La duración va inline porque es dinámica (prop speed).
  -->
  <div
    class="carousel-track gap-4"
    style={`animation-duration: ${speed}s;`}
  >
    {doubled.map((skill) => (
      <div class="
        flex flex-col items-center gap-3
        px-4 py-5
        w-44 shrink-0
        rounded-2xl
        border border-white/10
        bg-white/3
        transition-all duration-300
        hover:border-accent/30
        hover:bg-white/6
        hover:shadow-[0_0_22px_-4px_#aec3b026]
        cursor-default
      ">
        <!-- Icono 40×40 -->
        <div class="w-10 h-10 shrink-0">
          <Fragment set:html={iconMap[skill.name] ?? fallbackIcon} />
        </div>

        <!-- Nombre -->
        <span class="text-sm font-semibold text-high leading-tight text-center">
          {skill.name}
        </span>

        <!-- Descripción corta -->
        <p class="text-xs text-low leading-relaxed text-center">
          {skill.description}
        </p>
      </div>
    ))}
  </div>
</div>