---
import { data } from '../data/portfolioData';
---

<!--
  h-full para ocupar el 100% del contenedor sticky h-screen del index.astro
  Sin h-full, el efecto stacking no funciona correctamente
-->
<div class="h-full flex flex-col md:flex-row items-center justify-center gap-8 px-8 md:px-16 bg-surface">

  <!-- Columna izquierda: texto -->
  <div class="flex-1 min-w-70 flex flex-col items-center md:items-start text-center md:text-left">

    <h1 class="text-5xl md:text-6xl mb-4 font-light text-high leading-tight">
      Hola, soy <span class="font-bold">{data.personalInfo.name}</span>
    </h1>

    <h2 class="text-xl md:text-2xl text-accent mb-6 font-light tracking-wide">
      {data.personalInfo.role}
    </h2>

    <p class="max-w-130 text-base md:text-lg mb-10 text-mid leading-relaxed">
      {data.personalInfo.bio}
    </p>

    <div class="flex flex-wrap gap-3 justify-center md:justify-start">
      <a
        href="#projects"
        class="px-6 py-3 border border-high/30 text-high text-xs uppercase tracking-widest hover:border-accent hover:text-accent transition-all duration-200"
      >
        Ver Proyectos
      </a>
      <a
        href="#contact"
        class="px-6 py-3 border border-high/30 text-high text-xs uppercase tracking-widest hover:border-accent hover:text-accent transition-all duration-200"
      >
        Ver Contacto
      </a>
      <a
        href={data.personalInfo.cvLink}
        download
        class="px-6 py-3 border border-high/10 text-mid text-xs uppercase tracking-widest hover:border-accent hover:text-accent transition-all duration-200"
      >
        Descargar CV
      </a>
    </div>

  </div>

  <!-- Columna derecha: imagen -->
  <div class="flex-none flex justify-center">
    <img
      src={data.personalInfo.profileImage}
      alt={`Foto de perfil de ${data.personalInfo.name}`}
      class="w-52 md:w-72 rounded-full object-cover aspect-square border border-white/10"
      loading="eager"
    />
  </div>

</div>