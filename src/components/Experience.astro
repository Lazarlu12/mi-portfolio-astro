---
import { data } from '../data/portfolioData';
---

<!--
  Timeline vertical clásico: línea izquierda + puntos + contenido.
  Se implementa solo con border-l y position relative/absolute.
  Cero JavaScript, puro CSS.
-->
<div class="h-full flex flex-col justify-center px-8 md:px-16 pt-24 pb-8 bg-[#212121] overflow-y-auto shadow-[0_-8px_30px_rgba(0,0,0,0.4)]">

  <div class="max-w-3xl w-full mx-auto">

    <div class="mb-10">
      <span class="text-accent text-xs uppercase tracking-[0.3em] block mb-2">
        Trayectoria
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-high">
        Experiencia
      </h2>
    </div>

    <!--
      Concepto "last:": el pseudo-selector last-child de CSS.
      last:border-l-transparent oculta la línea del último ítem
      para que no quede una línea colgando al final del timeline.
    -->
    <div class="space-y-0">
      {data.experience.map((item) => (
        <div class="relative pl-8 pb-10 border-l border-white/10 last:border-l-transparent last:pb-0">

          <!--
            El punto del timeline: posicionado absolute respecto
            al div padre (que tiene relative).
            left-[-5px] lo centra sobre la línea border-l.
          -->
          <div class="absolute -left-1.25 top-1.5 w-2.5 h-2.5 rounded-full border-2 border-accent bg-[#212121]" />

          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-high font-semibold text-base">
                {item.role}
              </h3>
              <p class="text-accent text-sm mt-0.5">
                {item.company}
              </p>
            </div>
            <span class="text-low text-xs uppercase tracking-widest shrink-0 md:mt-1">
              {item.period}
            </span>
          </div>

          <p class="text-mid text-sm leading-relaxed">
            {item.description}
          </p>

        </div>
      ))}
    </div>

  </div>
</div>