---
/**
 * Navbar.astro — glassmorphism, fixed, responsive
 * Sin React: el toggle se maneja con vanilla JS en <script>.
 * transition:persist → el header y el overlay sobreviven View Transitions.
 */

const navLinks = [
  { href: '/',            label: 'Inicio'       },
  { href: '/sobre-mi',    label: 'Sobre Mi'      },
  { href: '/proyectos',   label: 'Proyectos'   },
  { href: '/experiencia', label: 'Experiencia' },
  { href: '/contacto',    label: 'Contacto'    },
];

const currentPath = Astro.url.pathname;
---

<!-- transition:persist: todo este bloque sobrevive cada navegación -->
<header
  class="fixed top-4 left-1/2 -translate-x-1/2 z-50
         w-[90%] md:w-[60%] lg:w-[48%]"
  transition:persist
>

  <!-- Pill de navegación -->
  <nav
    class="flex items-center justify-between px-5 py-3 rounded-full
           bg-white/5 backdrop-blur-md border border-white/10"
    aria-label="Navegación principal"
  >

    <!-- Logo -->
    <a
      href="/"
      class="font-display font-semibold text-sm text-high tracking-tight
             hover:text-accent transition-colors duration-200"
      aria-label="Ir al inicio"
    >
      Luca<span class="text-accent">.</span>
    </a>

    <!-- Desktop links: hidden en mobile, flex en md+ -->
    <ul id="desktop-nav" class="hidden md:flex items-center gap-1" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);

        return (
          <li>
            <a
              href={href}
              data-nav-link
              data-href={href}
              class:list={[
                'px-3 py-1.5 text-sm rounded-full transition-all duration-200',
                isActive
                  ? 'text-high bg-white/8'
                  : 'text-mid hover:text-high hover:bg-white/5',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!--
      Hamburger button — class="flex md:hidden" en el .astro file.
      Tailwind lo detecta 100% seguro acá (no en un .tsx).
      flex: lo hace visible en mobile | md:hidden: lo oculta en desktop.
    -->
    <button
      id="mobile-menu-btn"
      class="flex md:hidden items-center justify-center p-1.5
             text-mid hover:text-high transition-colors duration-200"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <!-- Hamburger (visible por defecto) -->
      <svg id="icon-burger" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 6h14M3 10h14M3 14h14"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <!-- X (oculto por defecto) -->
      <svg id="icon-x" class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M5 5L15 15M15 5L5 15"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

  </nav>

  <!--
    Overlay mobile — dentro del <header transition:persist>.
    Aunque sea child de un elemento fixed, al usar position:fixed propio
    se posiciona relativo al viewport (full screen). ✓
    
    Empieza invisible (opacity-0 pointer-events-none).
    JS agrega/quita opacity-100 y pointer-events-auto.
  -->
  <div
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
    class="fixed inset-0 -z-10
           flex flex-col items-center justify-center gap-6
           bg-surface/97 backdrop-blur-xl
           opacity-0 pointer-events-none
           transition-opacity duration-300 ease-out"
  >

    <nav>
      <ul class="flex flex-col items-center gap-1" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="text-[2.5rem] font-display font-semibold tracking-tight
                     text-mid hover:text-high transition-colors duration-200
                     block py-2 text-center"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="absolute bottom-8 text-xs text-low tracking-widest uppercase">
      Luca Lazarte · Frontend Developer
    </p>

  </div>

</header>

<script>
  /**
   * Vanilla JS para el toggle del menú mobile.
   * Este <script> corre UNA sola vez (Astro deduplica scripts).
   * Como el header tiene transition:persist, los elementos del DOM
   * persisten entre navegaciones → las referencias siguen siendo válidas.
   */

  const btn     = document.getElementById('mobile-menu-btn')!;
  const menu    = document.getElementById('mobile-menu')!;
  const iconBurger = document.getElementById('icon-burger')!;
  const iconX   = document.getElementById('icon-x')!;

  function openMenu() {
    menu.classList.remove('opacity-0', 'pointer-events-none', '-z-10');
    menu.classList.add('opacity-100', 'pointer-events-auto', 'z-40');
    iconBurger.classList.add('hidden');
    iconX.classList.remove('hidden');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('opacity-100', 'pointer-events-auto', 'z-40');
    menu.classList.add('opacity-0', 'pointer-events-none', '-z-10');
    iconBurger.classList.remove('hidden');
    iconX.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  // Click en el botón hamburguesa / X
  btn.addEventListener('click', () => {
    btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
  });

  // Cerrar al tocar un link del overlay
  menu.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', closeMenu)
  );

  /**
   * Actualizar link activo en desktop nav después de cada View Transition.
   * transition:persist mantiene el HTML viejo → hay que actualizarlo con JS.
   */
  document.addEventListener('astro:after-swap', () => {
    closeMenu(); // siempre cerramos el menú mobile al navegar

    const path = window.location.pathname;

    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach(link => {
      const href = link.dataset.href ?? '';
      const isActive = href === '/' ? path === '/' : path.startsWith(href);

      // Limpiamos clases de ambos estados y ponemos el correcto
      link.classList.remove('text-high', 'bg-white/8', 'text-mid', 'hover:text-high', 'hover:bg-white/5');

      if (isActive) {
        link.classList.add('text-high', 'bg-white/8');
      } else {
        link.classList.add('text-mid', 'hover:text-high', 'hover:bg-white/5');
      }
    });
  });
</script>