---
/**
 * Navbar.astro — glassmorphism, responsive
 * Sin React: el toggle se maneja con vanilla JS en <script>.
 * transition:persist → el header y el overlay sobreviven View Transitions.
 */

const navLinks = [
  { href: '/',        label: 'Inicio'       },
  { href: '/sobre-mi',    label: 'Sobre Mi'     },
  { href: '/proyectos',   label: 'Proyectos'   },
  { href: '/experiencia', label: 'Experiencia' },
  { href: '/contacto',    label: 'Contacto'    },
];

const currentPath = Astro.url.pathname;
---

<header
  class="w-[90%] lg:w-[60%] xl:w-[48%] mx-auto my-6"
  transition:persist
>

  <nav
        class="flex items-center justify-between px-5 py-3 rounded-full
          bg-black/65 border border-cyan-300/8 shadow-[0_10px_40px_-20px_rgba(56,189,248,0.12)]
          backdrop-blur-sm"
    aria-label="Navegación principal"
  >

 <a
  href="/"
  class="flex items-center hover:opacity-80 transition-opacity duration-200"
  aria-label="Ir al inicio"
>
  <!-- Ponemos un alto normal (h-10) pero lo agrandamos un 50% con scale-150 -->
  <img src="/logo.png" alt="Logo Luca Lazarte" class="h-10 w-auto scale-250 origin-left" />
</a>


    <ul id="desktop-nav" class="hidden lg:flex items-center gap-1" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);

        return (
          <li>
            <a
              href={href}
              data-nav-link
              data-href={href}
              class:list={[
                'relative inline-flex items-center justify-center px-3 py-1.5 text-sm rounded-full transition-all duration-200',
                isActive
                  ? 'text-cyan-300'
                  : 'text-mid hover:text-cyan-300',
              ]}
            >
              {label}
              <span class:list={[
                'absolute left-1/2 -bottom-1 -translate-x-1/2 h-1.5 w-1.5 rounded-full bg-cyan-300 shadow-[0_0_8px_rgba(56,189,248,0.18)] transition-opacity duration-200',
                isActive ? 'opacity-100' : 'opacity-0',
              ]} />
            </a>
          </li>
        );
      })}
    </ul>

    <button
      id="mobile-menu-btn"
      class="cursor-pointer flex lg:hidden items-center justify-center p-1.5 text-mid hover:text-high transition-colors duration-200"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-burger" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 6h14M3 10h14M3 14h14"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg id="icon-x" class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M5 5L15 15M15 5L5 15"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

  </nav>

  <div
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
    class="fixed inset-0 -z-10
           flex flex-col items-center justify-center gap-6
           bg-surface/97 backdrop-blur-xl
           opacity-0 pointer-events-none
           transition-opacity duration-300 ease-out"
  >

    <button
      id="mobile-menu-close"
      class="absolute top-6 right-6 flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-black/40 text-mid hover:text-high transition-colors duration-200"
      aria-label="Cerrar menú de navegación"
      type="button"
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M6 6L16 16M16 6L6 16"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <nav>
      <ul class="flex flex-col items-center gap-1" role="list">
        {navLinks.map(({ href, label }) => {
          const isActive = href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(href);

          return (
            <li>
              <a
                href={href}
                class:list={[
                   'text-[2.5rem] font-display font-semibold tracking-tight transition-colors duration-200 block py-2 text-center',
                  isActive ? 'text-cyan-300' : 'text-mid hover:text-cyan-300',
                ]}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <p class="absolute bottom-8 text-xs text-low tracking-widest uppercase">
      Luca Lazarte · Frontend Developer
    </p>

  </div>

</header>


<script>
  /**
   * Vanilla JS para el toggle del menú mobile.
   * Este <script> corre UNA sola vez (Astro deduplica scripts).
   * Como el header tiene transition:persist, los elementos del DOM
   * persisten entre navegaciones → las referencias siguen siendo válidas.
   */

  const btn     = document.getElementById('mobile-menu-btn')!;
  const menu    = document.getElementById('mobile-menu')!;
  const iconBurger = document.getElementById('icon-burger')!;
  const iconX   = document.getElementById('icon-x')!;

  function openMenu() {
    menu.classList.remove('opacity-0', 'pointer-events-none', '-z-10');
    menu.classList.add('opacity-100', 'pointer-events-auto', 'z-40');
    iconBurger.classList.add('hidden');
    iconX.classList.remove('hidden');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('opacity-100', 'pointer-events-auto', 'z-40');
    menu.classList.add('opacity-0', 'pointer-events-none', '-z-10');
    iconBurger.classList.remove('hidden');
    iconX.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  // Click en el botón hamburguesa / X
  btn.addEventListener('click', () => {
    btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
  });

  // Cerrar desde el botón X dentro del overlay
  const closeOverlayBtn = document.getElementById('mobile-menu-close');
  closeOverlayBtn?.addEventListener('click', closeMenu);

  // Evita que el click dentro del nav del overlay cierre el menú
  const mobileNav = menu.querySelector('nav');
  mobileNav?.addEventListener('click', event => event.stopPropagation());

  // Cerrar al tocar fuera de los enlaces / fuera del nav
  menu.addEventListener('click', event => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    if (target.closest('nav') || target.closest('#mobile-menu-close')) return;
    closeMenu();
  });

  // Cerrar al tocar un link del overlay
  menu.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', closeMenu)
  );

  /**
   * Actualizar link activo en desktop nav después de cada View Transition.
   * transition:persist mantiene el HTML viejo → hay que actualizarlo con JS.
   */
  document.addEventListener('astro:after-swap', () => {
    closeMenu(); // siempre cerramos el menú mobile al navegar

    const path = window.location.pathname;

    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach(link => {
      const href = link.dataset.href ?? '';
      const isActive = href === '/' ? path === '/' : path.startsWith(href);

      // Limpiamos clases de ambos estados y ponemos el correcto
      link.classList.remove('text-cyan-300', 'text-mid', 'hover:text-cyan-300');

      if (isActive) {
        link.classList.add('text-cyan-300');
      } else {
        link.classList.add('text-mid', 'hover:text-cyan-300');
      }

      // Actualizamos el punto activo (si existe) dentro del enlace
      const dot = link.querySelector('span');
      if (dot instanceof HTMLElement) {
        if (isActive) {
          dot.classList.remove('opacity-0');
          dot.classList.add('opacity-100');
        } else {
          dot.classList.remove('opacity-100');
          dot.classList.add('opacity-0');
        }
      }
    });
  });
</script>