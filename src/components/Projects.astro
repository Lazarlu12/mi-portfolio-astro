---
import { data } from '../data/portfolioData';
---

<!--
  PATRÓN CORRECTO para scroll interno en stacking:
  
  Capa 1 (h-full overflow-y-auto): altura fija = pantalla, activa el scroll
  Capa 2 (min-h-full flex flex-col justify-center): crece si hay más contenido
  
  Cuando el contenido entra: justify-center lo centra verticalmente ✓
  Cuando el contenido no entra: la capa 2 crece, la capa 1 habilita scroll ✓
-->
<div class="h-full bg-[#1E1E1E] shadow-[0_-8px_30px_rgba(0,0,0,0.4)] overflow-y-auto">

  <div class="min-h-full flex flex-col justify-center
              px-6 md:px-16 py-20 md:py-24">

    <div class="max-w-5xl w-full mx-auto">

      <!-- Encabezado de sección -->
      <div class="mb-6 md:mb-8">
        <span class="text-accent text-xs uppercase tracking-[0.3em] block mb-2">
          Mi trabajo
        </span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-high tracking-tight">
          Proyectos
        </h2>
      </div>

      <!-- Grid: 1 col en mobile, 2 en desktop -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
        {data.projects.map((project) => (
          <article class="border border-white/10 p-4 md:p-6
                          hover:border-accent/40 transition-all duration-200 group">

            <div class="flex items-start justify-between mb-2 md:mb-3">
              <h3 class="font-display font-semibold text-sm md:text-base text-high
                         group-hover:text-accent transition-colors duration-200">
                {project.name}
              </h3>

              <div class="flex gap-3 ml-4 shrink-0">
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver demo de ${project.name}`}
                  class="text-low hover:text-accent transition-colors duration-200
                         text-xs uppercase tracking-widest"
                >
                  Demo ↗
                </a>
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver código de ${project.name}`}
                  class="text-low hover:text-accent transition-colors duration-200
                         text-xs uppercase tracking-widest"
                >
                  Repo ↗
                </a>
              </div>
            </div>

            <!--
              line-clamp-2 en mobile: limita la descripción a 2 líneas
              para que los 4 proyectos quepan sin scroll en pantallas medianas.
              En desktop (md:line-clamp-none) muestra el texto completo.
            -->
            <p class="text-mid text-xs md:text-sm leading-relaxed mb-3 md:mb-4
                      line-clamp-2 md:line-clamp-none">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-1.5 md:gap-2">
              {project.stack.map((tech) => (
                <span class="text-xs text-low border border-white/10 px-2 py-0.5">
                  {tech}
                </span>
              ))}
            </div>

          </article>
        ))}
      </div>

    </div>
  </div>
</div>