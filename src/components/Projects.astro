---
import { data } from '../data/portfolioData';
---

<!--
  overflow-y-auto: si el contenido supera la altura de la pantalla
  (en móviles chicos), el usuario puede hacer scroll DENTRO de la sección.
  Sin esto, el contenido quedaría cortado.

  pt-24: espacio para que la Navbar fija no tape el título.
-->
<div class="h-full flex flex-col justify-center px-8 md:px-16 pt-24 pb-8 bg-[#1E1E1E] overflow-y-auto shadow-[0_-8px_30px_rgba(0,0,0,0.4)]">

  <div class="max-w-5xl w-full mx-auto">

    <!-- Encabezado de sección — patrón consistente con About -->
    <div class="mb-8">
      <span class="text-accent text-xs uppercase tracking-[0.3em] block mb-2">
        Mi trabajo
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-high">
        Proyectos
      </h2>
    </div>

    <!--
      grid con gap-4: los 4 proyectos en 2 columnas en desktop,
      1 columna en móvil. Simple y limpio.
    -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {data.projects.map((project) => (
        <article class="border border-white/10 p-6 hover:border-accent/40 transition-all duration-300 group">

          <div class="flex items-start justify-between mb-3">
            <h3 class="text-high font-semibold text-base group-hover:text-accent transition-colors duration-200">
              {project.name}
            </h3>

            <!-- Links del proyecto -->
            <div class="flex gap-4 ml-4 shrink-0">
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Ver demo de ${project.name}`}
                class="text-low hover:text-accent transition-colors duration-200 text-xs uppercase tracking-widest"
              >
                Demo ↗
              </a>

              <a
                href={project.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Ver código de ${project.name}`}
                class="text-low hover:text-accent transition-colors duration-200 text-xs uppercase tracking-widest"
              >
                Repo ↗
              </a>
            </div>
          </div>
        
          <p class="text-mid text-sm leading-relaxed mb-4">
            {project.description}
          </p>

          <!-- Stack tecnológico como pills -->
          <div class="flex flex-wrap gap-2">
            {project.stack.map((tech) => (
              <span class="text-xs text-low border border-white/10 px-2 py-0.5">
                {tech}
              </span>
            ))}
          </div>

        </article>
      ))}
    </div>

  </div>
</div>