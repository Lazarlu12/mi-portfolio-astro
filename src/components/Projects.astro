---
import { data } from '../data/portfolioData';
---

<section 
  id="proyectos"
  aria-labelledby="titulo-proyectos"
  class="h-full bg-[#1E1E1E] shadow-[0_-8px_30px_rgba(0,0,0,0.4)] overflow-y-auto"
>

  <div class="min-h-full flex flex-col justify-center px-6 md:px-16 py-20 md:py-24">

    <div class="max-w-5xl w-full mx-auto">

      <header class="mb-6 md:mb-8">
        <span class="text-accent text-xs uppercase tracking-[0.3em] block mb-2">
          Mi trabajo
        </span>
        <h2 id="titulo-proyectos" class="text-3xl md:text-4xl font-display font-bold text-high tracking-tight">
          Proyectos
        </h2>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {data.projects.map((project) => (
          <article 
            itemscope 
            itemtype="https://schema.org/SoftwareApplication"
            class="border border-white/10 rounded flex flex-col bg-[#1E1E1E] overflow-hidden"
          >

            {project.image && (
              <a 
                href={project.liveUrl || project.repoUrl || '#'} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="block overflow-hidden shrink-0 border-b border-white/10"
                aria-label={`Ver detalles del proyecto ${project.name}`}
              >
                <img 
                  itemprop="image"
                  src={project.image} 
                  alt={`Interfaz de usuario del proyecto ${project.name}`} 
                  class="w-full h-[200px] object-cover block transition-transform duration-500 ease-out hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}

            <div class="p-5 md:p-6 flex flex-col flex-grow">
              
              <header class="flex items-start justify-between mb-3">
                <h3 itemprop="name" class="font-display font-semibold text-base text-high">
                  {project.name}
                </h3>

                <nav class="flex gap-3 ml-4 shrink-0 mt-0.5" aria-label={`Enlaces del proyecto ${project.name}`}>
                  {project.liveUrl && (
                    <a
                      itemprop="url"
                      href={project.liveUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={`Ver demo en vivo de ${project.name}`}
                      aria-label={`Ver demo en vivo de ${project.name}`}
                      class="text-low hover:text-accent transition-colors duration-200 text-xs uppercase tracking-widest"
                    >
                      Demo ↗
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      itemprop="codeRepository"
                      href={project.repoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={`Ver repositorio de código de ${project.name}`}
                      aria-label={`Ver código fuente de ${project.name} en GitHub`}
                      class="text-low hover:text-accent transition-colors duration-200 text-xs uppercase tracking-widest"
                    >
                      Repo ↗
                    </a>
                  )}
                </nav>
              </header>

              <p itemprop="description" class="text-mid text-xs md:text-sm leading-relaxed mb-4 md:mb-5 line-clamp-2 md:line-clamp-none flex-grow">
                {project.description}
              </p>

              <footer aria-label="Tecnologías utilizadas">
                <ul class="flex flex-wrap gap-2 mt-auto">
                  {project.stack.map((tech) => (
                    <li itemprop="applicationCategory" class="text-xs text-low border border-white/10 px-2.5 py-1 rounded-sm">
                      {tech}
                    </li>
                  ))}
                </ul>
              </footer>

            </div>

          </article>
        ))}
      </div>

    </div>
  </div>
</section>